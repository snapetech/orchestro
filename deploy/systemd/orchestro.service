[Unit]
Description=Orchestro API Service
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/code/orchestro
Environment=ORCHESTRO_HOME=%h/.orchestro
ExecStart=%h/code/orchestro/.venv/bin/orchestro serve --host 127.0.0.1 --port 8765
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
