{
  "suite": "agent",
  "cases": [
    {
      "id": "tool-loop-subprocess",
      "goal": "use a local tool and then finish",
      "backend": "subprocess-command",
      "strategy": "tool-loop",
      "match": "contains",
      "expected": "done after tool",
      "expected_status": "done",
      "expected_events": [
        "tool_called",
        "tool_result",
        "run_completed"
      ],
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'if printf \"%s\" \"$ORCHESTRO_PROMPT_CONTEXT\" | grep -q \"Tool step\"; then printf \"{\\\"action\\\":\\\"final\\\",\\\"content\\\":\\\"done after tool\\\"}\"; else printf \"{\\\"action\\\":\\\"tool\\\",\\\"tool\\\":\\\"pwd\\\",\\\"argument\\\":\\\"\\\"}\"; fi'"
      }
    },
    {
      "id": "reflect-retry-subprocess",
      "goal": "retry once and recover",
      "backend": "subprocess-command",
      "strategy": "reflect-retry",
      "match": "contains",
      "expected": "recovered",
      "expected_status": "done",
      "expected_events": [
        "reflection",
        "retry_scheduled",
        "run_completed"
      ],
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'flag=.orchestro/bench-reflect-flag; if [ ! -f \"$flag\" ]; then mkdir -p .orchestro; touch \"$flag\"; printf fail >&2; exit 1; else rm -f \"$flag\"; printf recovered; fi'"
      }
    },
    {
      "id": "approval-and-operator-note",
      "goal": "use an approval-gated tool and then finish with the injected note",
      "backend": "subprocess-command",
      "strategy": "tool-loop",
      "match": "contains",
      "expected": "saw BENCH_NOTE",
      "expected_status": "done",
      "expected_events": [
        "approval_requested",
        "operator_input_queued",
        "operator_input_received",
        "tool_called",
        "tool_result",
        "run_completed"
      ],
      "approval_pattern": "bash *",
      "operator_note": "BENCH_NOTE",
      "operator_note_after_approval": true,
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'if printf \"%s\" \"$ORCHESTRO_PROMPT_CONTEXT\" | grep -q \"Tool step 1\"; then if printf \"%s\" \"$ORCHESTRO_PROMPT_CONTEXT\" | grep -q \"BENCH_NOTE\"; then printf \"{\\\"action\\\":\\\"final\\\",\\\"content\\\":\\\"saw BENCH_NOTE\\\"}\"; else printf \"{\\\"action\\\":\\\"final\\\",\\\"content\\\":\\\"missing BENCH_NOTE\\\"}\"; fi; else printf \"{\\\"action\\\":\\\"tool\\\",\\\"tool\\\":\\\"bash\\\",\\\"argument\\\":\\\"printf benchmark\\\"}\"; fi'"
      }
    },
    {
      "id": "reflect-retry-terminal-failure",
      "goal": "retry once and classify the final failure",
      "backend": "subprocess-command",
      "strategy": "reflect-retry",
      "match": "contains",
      "expected": "",
      "expected_status": "failed",
      "expected_events": [
        "reflection",
        "recovery_attempted",
        "retry_scheduled",
        "run_failed",
        "postmortem_recorded"
      ],
      "expected_failure_category": "general_failure",
      "min_recovery_attempts": 1,
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'printf fail >&2; exit 1'"
      }
    },
    {
      "id": "backend-unreachable-failover",
      "goal": "recover from an unreachable backend by falling back",
      "backend": "openai-compat",
      "strategy": "reflect-retry",
      "match": "contains",
      "expected": "Mock backend response",
      "expected_status": "done",
      "expected_events": [
        "reflection",
        "recovery_attempted",
        "retry_scheduled",
        "run_completed"
      ],
      "env": {
        "ORCHESTRO_OPENAI_BASE_URL": "",
        "ORCHESTRO_OPENAI_MODEL": ""
      }
    },
    {
      "id": "context-overflow-compaction",
      "goal": "compact oversized context and recover",
      "backend": "subprocess-command",
      "strategy": "reflect-retry",
      "match": "contains",
      "expected": "compacted-ok",
      "expected_status": "done",
      "expected_events": [
        "reflection",
        "recovery_attempted",
        "retry_scheduled",
        "run_completed"
      ],
      "min_recovery_attempts": 1,
      "prompt_context": "",
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'if printf \"%s\" \"$ORCHESTRO_PROMPT_CONTEXT\" | grep -q \"context compacted by Orchestro\"; then printf compacted-ok; else printf \"context overflow exceeded\" >&2; exit 1; fi'"
      },
      "providers": []
    },
    {
      "id": "tool-crash-simplify-strategy",
      "goal": "simplify strategy after repeated tool crash",
      "backend": "subprocess-command",
      "strategy": "reflect-retry",
      "match": "contains",
      "expected": "direct-ok",
      "expected_status": "done",
      "expected_events": [
        "reflection",
        "recovery_attempted",
        "retry_scheduled",
        "run_completed"
      ],
      "min_recovery_attempts": 2,
      "env": {
        "ORCHESTRO_SUBPROCESS_COMMAND": "bash -lc 'if [ \"$ORCHESTRO_STRATEGY\" = \"direct\" ]; then printf direct-ok; else printf tool permission denied >&2; exit 1; fi'"
      }
    }
  ]
}
