# Orchestro environment variables
# Copy to .env and fill in values. Never commit .env.
#
# Most of these are optional — defaults are shown in comments.

# ---------------------------------------------------------------------------
# Database and storage
# ---------------------------------------------------------------------------

# Override the root data directory (default: <repo>/.orchestro)
# ORCHESTRO_HOME=/path/to/your/orchestro-data

# ---------------------------------------------------------------------------
# Backend: openai-compat (generic, used for vllm and other OpenAI-API servers)
# ---------------------------------------------------------------------------

# Base URL for the OpenAI-compatible API (required for openai-compat backend)
ORCHESTRO_OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# Model name to send in requests (required if the server needs it)
ORCHESTRO_OPENAI_MODEL=Qwen/Qwen3-4B

# API key (most local servers accept any non-empty string)
ORCHESTRO_OPENAI_API_KEY=local

# ---------------------------------------------------------------------------
# Backend: vllm named profiles (vllm-fast, vllm-balanced, vllm-coding)
# These use the OpenAI-compat backend internally.
# Default ports: fast=8000, balanced=8001, coding=8002
# ---------------------------------------------------------------------------

# ORCHESTRO_VLLM_FAST_BASE_URL=http://127.0.0.1:8000/v1
# ORCHESTRO_VLLM_FAST_MODEL=Qwen/Qwen3-4B

# ORCHESTRO_VLLM_BALANCED_BASE_URL=http://127.0.0.1:8001/v1
# ORCHESTRO_VLLM_BALANCED_MODEL=Qwen/Qwen3-8B-FP8

# ORCHESTRO_VLLM_CODING_BASE_URL=http://127.0.0.1:8002/v1
# ORCHESTRO_VLLM_CODING_MODEL=Qwen/Qwen3-4B

# ---------------------------------------------------------------------------
# Backend: ollama-amd (Ollama running on AMD GPU, port 11434)
# ---------------------------------------------------------------------------

# ORCHESTRO_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# ORCHESTRO_OLLAMA_MODEL=qwen2.5-coder:7b

# ---------------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------------

# Embedding provider: 'hash' (debug, no server) or 'openai-compat'
# ORCHESTRO_RETRIEVAL_PROVIDER=hash

# Required if ORCHESTRO_RETRIEVAL_PROVIDER=openai-compat
# ORCHESTRO_EMBED_BASE_URL=http://127.0.0.1:8000/v1
# ORCHESTRO_EMBED_MODEL=nomic-embed-text
# ORCHESTRO_EMBED_API_KEY=local

# ---------------------------------------------------------------------------
# Subprocess backend
# Used for testing and scripted workflows. The command receives the goal
# via environment variables and is expected to print a JSON action.
# ---------------------------------------------------------------------------

# ORCHESTRO_SUBPROCESS_COMMAND=bash -lc 'my-agent-script.sh'

# ---------------------------------------------------------------------------
# Agent CLI backends (claude-code, codex, kilocode, cursor)
# These backends delegate to installed AI agent CLIs.
# All four are registered automatically; each is only included in routing
# when its binary is found on PATH (no configuration needed if installed).
# ---------------------------------------------------------------------------

# Override the binary name/path for each CLI:
# ORCHESTRO_CLAUDE_BINARY=claude
# ORCHESTRO_CODEX_BINARY=codex
# ORCHESTRO_KILOCODE_BINARY=kilocode
# ORCHESTRO_CURSOR_BINARY=cursor-agent

# Claude Code CLI options:
# ORCHESTRO_CLAUDE_PRINT_FLAG=--print      # flag used for non-interactive mode
# ORCHESTRO_CLAUDE_OUTPUT_FORMAT=text      # or: json, stream-json

# Codex CLI options:
# ORCHESTRO_CODEX_APPROVAL_MODE=full-auto  # other values are passed to --sandbox

# Cursor Agent CLI options:
# ORCHESTRO_CURSOR_EXTRA_ARGS=            # extra flags passed to cursor-agent --print --mode ask

# ---------------------------------------------------------------------------
# Shell and run defaults
# ---------------------------------------------------------------------------

# Default backend when --backend is not specified (default: auto)
# ORCHESTRO_DEFAULT_BACKEND=auto

# Default strategy (default: direct)
# ORCHESTRO_DEFAULT_STRATEGY=direct

# Default domain (default: none)
# ORCHESTRO_DEFAULT_DOMAIN=coding

# Default context providers, comma-separated
# ORCHESTRO_DEFAULT_PROVIDERS=instructions,lexical,semantic,corrections,interactions,postmortems,collections

# ---------------------------------------------------------------------------
# API server (FastAPI service, optional)
# ---------------------------------------------------------------------------

# ORCHESTRO_API_HOST=127.0.0.1
# ORCHESTRO_API_PORT=7000
